# .env.example — zabctl environment variables
# Copy to .env and fill in values for local development.
# .env is gitignored — NEVER commit it.
# These variables have the HIGHEST priority, overriding CLI params and config file.

# Zabbix server URL (trailing slash optional)
# ZABCTL_SERVER=http://zabbix.local/

# API token (preferred — use this for automation and agent access)
# Obtain from Zabbix UI: Administration → API tokens → Create API token
# ZABCTL_API_TOKEN=zbx_...

# Username and password (fallback if no API token — token always wins when both set)
# ZABCTL_USERNAME=Admin
# ZABCTL_PASSWORD=zabbix

# Named context from ~/.config/zabctl/config.yaml
# ZABCTL_CONTEXT=homelab

# Default output format: table | json | jsonl | yaml | wide
# ZABCTL_OUTPUT=table

# TLS settings
# ZABCTL_INSECURE=false                         # set true to skip TLS verification (dev only)
# ZABCTL_CA_BUNDLE=/etc/ssl/certs/corp-ca.pem   # custom CA bundle or directory (PEM)
# ZABCTL_CLIENT_CERT=~/.config/zabctl/client.crt # mutual TLS client certificate
# ZABCTL_CLIENT_KEY=~/.config/zabctl/client.key  # mutual TLS client private key

# Proxy
# ZABCTL_PROXY=http://proxy.corp:8080
# ZABCTL_NO_PROXY=localhost,127.0.0.1,.homelab
